               <assignment id="a1jGrHZ0zmiMbbu7GR3wHlWa-Assignmentcd012b65-863e-4be5-98c0-1b956b557887">
                  <title>Get Matching Vectors</title>
                  <operation source="formula" to="output.Matches_Vectors_Array">
                     <expression language="XQuery">for $candidate in $output.response[1]/matches
return if ($candidate/score &gt; $input.In_Score_Cuttoff  ) then

if($input.In_Type="RAG") then 
&lt;VectorMatchEntry&gt;
    &lt;ID&gt; {$candidate/id/text() }&lt;/ID&gt;
    &lt;Score&gt;{ $candidate/score/text() }&lt;/Score&gt;
    &lt;Text&gt; {$candidate/metadata/text/text()} &lt;/Text&gt;
&lt;/VectorMatchEntry&gt;
else
&lt;VectorMatchEntry&gt;
    &lt;ID&gt; {$candidate/id/text() }&lt;/ID&gt;
    &lt;Score&gt;{ $candidate/score/text() }&lt;/Score&gt;
    &lt;Text&gt; {$candidate/metadata/text/text()} &lt;/Text&gt;
    &lt;JiraLink&gt;{$candidate/metadata/jira_link}&lt;/JiraLink&gt;
&lt;/VectorMatchEntry&gt;
else ()

</expression>
                  </operation>
