               <assignment id="a1jGrHZ0zmiMbbu7GR3wHlWa-Assignment04a80d39-4e72-4fea-b1c3-5fdd90da439e">
                  <title>Prepare Request PO</title>
                  <operation source="formula" to="temp.Tmp_Get_Vectors">
                     <expression language="XQuery">for $arr in $input.Vectors_Array//values
return &lt;vector&gt;{$arr}&lt;/vector&gt;
</expression>
                  </operation>
                  <operation source="formula" to="temp.Tmp_Request">
                     <expression language="XQuery">&lt;root xmlns:m="urn:informatica:ae:xquery:json2xml:meta-data"&gt;
{ $temp.Tmp_Get_Vectors }
&lt;topK&gt;{ $temp.Tmp_Top_K  }&lt;/topK&gt;
&lt;includeMetadata&gt;true&lt;/includeMetadata&gt;
&lt;/root&gt;</expression>
                  </operation>
                  <link id="oc505ad08-0113-4308-950e-aedb5db21331"
