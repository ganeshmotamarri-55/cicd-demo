                  <operation source="formula" to="temp.temp content">
                     <expression language="XQuery">let $doc := doc("file:///E:/Projects/Training/SrcFiles/CAI/Text.xml")
return 
concat(
    'ID,NAME,AGE,JOB,PHONE,ADDRESS',
    '&amp;#10;',
    string-join(
        for $emp in $doc/files/file
        return concat(
            $emp/id, ',',
            $emp/name, ',',
            $emp/age, ',',
            $emp/job, ',',
            $emp/phone, ',',
            $emp/address
        ),
        '&amp;#10;'
    )
)</expression>
