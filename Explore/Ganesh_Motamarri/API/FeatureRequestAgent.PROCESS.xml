               <assignment id="mejxlkz3">
                  <title>Return Content from Response</title>
                  <operation source="formula" to="temp.Tmp_Summary">
                     <expression language="XQuery">let $startPos := string-length(substring-before($output.text  , 'Summary:')) + string-length('Summary:')
let $endPos := string-length(substring-before($output.text  , 'Description:'))
let $length := $endPos - $startPos
let $result := substring($output.text  , $startPos + 1, $length)
return normalize-space($result)</expression>
