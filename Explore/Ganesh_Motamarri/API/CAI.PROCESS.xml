               <assignment id="a1k5WIRbpCIspefB30h5BMIR-Assignmentb2ef3b66-5d5e-4e3b-ab2d-63ffb05d2458">
                  <title>Assignment 1</title>
                  <operation source="constant" to="temp.XML_temp">&lt;libreria&gt;   &lt;Libros&gt;       &lt;libro categoria="COOKING" codigo='1'&gt;         &lt;titulo leng="en"&gt;Everyday Italian&lt;/titulo&gt;         &lt;autor&gt;Giada De Laurentiis&lt;/autor&gt;         &lt;anyo&gt;2005&lt;/anyo&gt;         &lt;precio&gt;30.00&lt;/precio&gt;       &lt;/libro&gt;        &lt;libro categoria="CHILDREN" codigo='2'&gt;         &lt;titulo leng="en"&gt;Harry Potter&lt;/titulo&gt;         &lt;autor&gt;J K. Rowling&lt;/autor&gt;         &lt;anyo&gt;2005&lt;/anyo&gt;         &lt;precio&gt;29.99&lt;/precio&gt;       &lt;/libro&gt;        &lt;libro categoria="WEB" codigo='3'&gt;         &lt;titulo leng="en"&gt;XQuery Kick Start&lt;/titulo&gt;         &lt;autor&gt;James McGovern&lt;/autor&gt;         &lt;autor&gt;Per Bothner&lt;/autor&gt;         &lt;autor&gt;Kurt Cagle&lt;/autor&gt;         &lt;autor&gt;James Linn&lt;/autor&gt;         &lt;autor&gt;Vaidyanathan Nagarajan&lt;/autor&gt;         &lt;anyo&gt;2003&lt;/anyo&gt;         &lt;precio&gt;49.99&lt;/precio&gt;       &lt;/libro&gt;        &lt;libro categoria="WEB" codigo='4'&gt;         &lt;titulo leng="en"&gt;Learning XML&lt;/titulo&gt;         &lt;autor&gt;Erik T. Ray&lt;/autor&gt;         &lt;anyo&gt;2003&lt;/anyo&gt;         &lt;precio&gt;39.95&lt;/precio&gt;       &lt;/libro&gt;        &lt;libro categoria="COMEDY" codigo='5'&gt;         &lt;titulo leng="es"&gt;El hechizado por fuerza&lt;/titulo&gt;         &lt;autor&gt;Antonio de Zamora&lt;/autor&gt;         &lt;anyo&gt;2017&lt;/anyo&gt;         &lt;precio&gt;690.95&lt;/precio&gt;       &lt;/libro&gt;   &lt;/Libros&gt;    &lt;almacen&gt;     &lt;comprados&gt;       &lt;codigo&gt;1&lt;/codigo&gt;       &lt;codigo&gt;2&lt;/codigo&gt;       &lt;codigo&gt;5&lt;/codigo&gt;     &lt;/comprados&gt;     &lt;pendientes&gt;       &lt;codigo&gt;3&lt;/codigo&gt;       &lt;codigo&gt;4&lt;/codigo&gt;     &lt;/pendientes&gt;   &lt;/almacen&gt; &lt;/libreria&gt;</operation>
                  <link id="w400d5ebf-064f-4896-9736-50f2c6add844"
                        targetId="a1k5WIRbpCIspefB30h5BMIR-Assignmentebe019b5-8758-42ef-96d6-fcf36e25686c"/>
               </assignment>
               <assignment id="a1k5WIRbpCIspefB30h5BMIR-Assignmentebe019b5-8758-42ef-96d6-fcf36e25686c">
                  <title>Assignment to XML_Flattened_temp</title>
                  <operation source="formula" to="temp.XML_Flattened_temp">
                     <expression language="XQuery">for $libro in $temp.XML_temp/libreria/Libros/libro
for $autor in $libro/autor
return
&lt;row&gt;
  &lt;titulo&gt;{data($libro/titulo)}&lt;/titulo&gt;
  &lt;autor&gt;{data($autor)}&lt;/autor&gt;
  &lt;anyo&gt;{data($libro/anyo)}&lt;/anyo&gt;
  &lt;precio&gt;{data($libro/precio)}&lt;/precio&gt;
  &lt;idioma&gt;{
    if ($libro/titulo/@leng = "en") then "English"
    else if ($libro/titulo/@leng = "es") then "Spanish"
    else ""
  }&lt;/idioma&gt;
&lt;/row&gt;
</expression>
                  </operation>
                  <operation source="formula" to="temp.row_count">
                     <expression language="XQuery">count($temp.XML_Flattened_temp/row)</expression>
                  </operation>
                  <link id="eb0e6178f-7a69-4826-81cc-2fc7ec51d441"
                        targetId="a1k5WIRbpCIspefB30h5BMIR-Loope46374e0-82b4-4a1d-b702-dd593801b26c"/>
               </assignment>
               <repeat id="a1k5WIRbpCIspefB30h5BMIR-Loope46374e0-82b4-4a1d-b702-dd593801b26c"
                       title="Loop 1"
                       type="While">
                  <condition source="formula">
                     <expression language="XQuery">$temp.row_count &gt; 0</expression>
                  </condition>
                  <flow id="c1bd13da7-3605-4d5e-ac0d-e55a4050924b">
                     <assignment id="a1k5WIRbpCIspefB30h5BMIR-Assignment9eadfe03-6563-4b0a-bc94-5415dca36067">
                        <title>Assignment to titulo_temp, autor_temp, etc,</title>
                        <operation source="formula" to="temp.titulo_temp">
                           <expression language="XQuery">$temp.XML_Flattened_temp /row[1]/titulo/text()</expression>
                        </operation>
                        <operation source="formula" to="temp.autor_temp">
                           <expression language="XQuery">$temp.XML_Flattened_temp /row[1]/autor/text()</expression>
                        </operation>
                        <operation source="formula" to="temp.anyo_temp">
                           <expression language="XQuery">$temp.XML_Flattened_temp /row[1]/anyo/text()</expression>
                        </operation>
                        <operation source="formula" to="temp.precio_temp">
                           <expression language="XQuery">$temp.XML_Flattened_temp /row[1]/precio/text()</expression>
                        </operation>
                        <operation source="formula" to="temp.idioma_temp">
                           <expression language="XQuery">$temp.XML_Flattened_temp /row[1]/idioma/text()</expression>
                        </operation>
                        <link id="cb851f942-9443-477e-b5a0-247fceead5bf"
                              targetId="a1k5WIRbpCIspefB30h5BMIR-Create484b2cc9-b310-4ac7-8745-37a5eecbb19c"/>
                     </assignment>
                     <assignment id="a1k5WIRbpCIspefB30h5BMIR-Assignment7e241f84-a87f-4668-858e-5bde2b4c0b57">
                        <title>Assignment to XML_Flattened_temp, row_count</title>
                        <operation source="formula" to="temp.XML_Flattened_temp">
                           <expression language="XQuery">$temp.XML_Flattened_temp /row[position() &gt; 1]
</expression>
                        </operation>
                        <operation source="formula" to="temp.row_count">
                           <expression language="XQuery">$temp.row_count - 1</expression>
                        </operation>
                     </assignment>
                     <create id="a1k5WIRbpCIspefB30h5BMIR-Create484b2cc9-b310-4ac7-8745-37a5eecbb19c">
