            <flow id="s922e05da-8a3f-48ab-9eae-4c70d6c02d5d">
               <start id="i7251f887-b7b3-4357-b78f-b690a8595508">
                  <link id="mfk0qqog" targetId="a17MAawUYjIkOeVv7vGImAoE-me9omfcd"/>
               </start>
               <assignment id="a17MAawUYjIkOeVv7vGImAoE-me9omfcd">
                  <title>Prepare Query Request</title>
                  <operation source="field" to="temp.Tmp_Query_Agent_Response">input.Planner[1]/Attributes[1]/QueryAgentResponse</operation>
                  <operation source="field" to="temp.Tmp_Email_Body">input.Planner[1]/Attributes[1]/EmailBody</operation>
                  <operation source="formula" to="temp.Tmp_Config_Parameters">
                     <expression language="XQuery">&lt;generationConfig&gt;
      &lt;stopSequences&gt;???&lt;/stopSequences&gt;
      &lt;candidateCount&gt;1&lt;/candidateCount&gt;
      &lt;maxOutputTokens&gt;300&lt;/maxOutputTokens&gt;
      &lt;temperature&gt;0.2&lt;/temperature&gt;
      &lt;topP&gt;0.2&lt;/topP&gt;
      &lt;topK&gt;2&lt;/topK&gt;
&lt;/generationConfig&gt;</expression>
                  </operation>
                  <operation source="formula" to="temp.Tmp_Configuration_Prompt">
                     <expression language="XQuery">' You are given an input text:" ' || 
$temp.Tmp_Query_Agent_Response  || '"
, which is a response to an e-mail from a customer: "' ||
$temp.Tmp_Email_Body   || '"

Generate a concise summary of the text. The response needs to be precise and presented in a friendly tone. Make sure that your response is relevant to the provided e-mail from the customer and can help the user solve the problem explained in the e-mail. Make sure that all information that could be helpful in solving the customer problem and is present in the input text is retained in your response. Make sure your response is complete and maximally 300 tokens long.  ???

'
</expression>
                  </operation>
                  <operation source="formula" to="temp.Tmp_Query_Request">
                     <expression language="XQuery">&lt;Generate_Content_Request&gt;
   &lt;contents&gt;
      &lt;parts&gt;
         &lt;text&gt;{$temp.Tmp_Configuration_Prompt}  &lt;/text&gt;
      &lt;/parts&gt;
      &lt;role&gt;user&lt;/role&gt;
   &lt;/contents&gt;
 &lt;generationConfig&gt;
      &lt;stopSequences&gt;{$temp.Tmp_Config_Parameters[1]/stopSequences }&lt;/stopSequences&gt;
      &lt;candidateCount&gt;{$temp.Tmp_Config_Parameters[1]/candidateCount  }&lt;/candidateCount&gt;
      &lt;maxOutputTokens&gt;{$temp.Tmp_Config_Parameters[1]/maxOutputTokens  }&lt;/maxOutputTokens&gt;
      &lt;temperature&gt;{$temp.Tmp_Config_Parameters[1]/temperature  }&lt;/temperature&gt;
      &lt;topP&gt;{$temp.Tmp_Config_Parameters[1]/topP  }&lt;/topP&gt;
      &lt;topK&gt;{$temp.Tmp_Config_Parameters[1]/topK  }&lt;/topK&gt;
   &lt;/generationConfig&gt;
&lt;/Generate_Content_Request&gt;
</expression>
                  </operation>
                  <link id="d3a90645d-1fbd-44f9-be0d-96c2041475c3" targetId="mev3isho"/>
               </assignment>
               <assignment id="a17MAawUYjIkOeVv7vGImAoE-me9omfcy">
                  <title>Return Content from Response</title>
                  <operation source="field"
                             to="input.Planner[1]/Attributes[1]/SummarizerAgentResponse">output.text</operation>
                  <operation source="field" to="output.PlannerOut">input.Planner</operation>
                  <link id="lbbd1feba-3162-4b89-8f38-086fdf4fa407"
                        targetId="a17MAawUYjIkOeVv7vGImAoE-md5qxiut"/>
               </assignment>
               <eventContainer id="mev3isho">
                  <service id="a17MAawUYjIkOeVv7vGImAoE-me9omfcn">
                     <title>Generate Content</title>
                     <serviceName>GeminiConnection:Generate Content</serviceName>
                     <serviceGUID>0BNr3j3wvwukTj4JucgxsM</serviceGUID>
                     <serviceInput>
                        <parameter name="model" source="field">input.Planner[1]/Attributes[1]/ModelVersion</parameter>
                        <parameter name="requestBody" source="field">temp.Tmp_Query_Request</parameter>
                     </serviceInput>
                  </service>
                  <flow id="mev3ishq">
                     <link id="mev3ishr" targetId="mev3isho" type="containerLink"/>
                  </flow>
                  <flow id="mev3isht">
                     <subflow id="mev3isib">
                        <title>GenericErrorHandlerLLM</title>
                        <subflowGUID>0n6qhvyIVgwlFmCA1wnzEx</subflowGUID>
                        <subflowPath>Generic_Error_Handler</subflowPath>
                        <runForEach>false</runForEach>
                        <input>
                           <parameter name="In_Code" source="field" updatable="true">output.faultInfo[1]/code</parameter>
                           <parameter name="In_Retry" source="field" updatable="true">temp.Tmp_Retry</parameter>
                           <parameter name="In_Service" source="constant" updatable="true"/>
                        </input>
                        <outputDef>
                           <field name="Out_Retry" type="int">
                              <options>
                                 <option name="required">false</option>
                              </options>
                           </field>
                        </outputDef>
                        <link id="mev3isis" targetId="mev3isir"/>
                     </subflow>
                     <assignment id="mev3isir">
                        <title>Increment Retry Attempt</title>
                        <operation source="field" to="temp.Tmp_Retry">output.Out_Retry</operation>
                        <link id="mev3isj2" targetId="mev3isj0"/>
                     </assignment>
                     <jumpTo id="mev3isj0">
                        <link id="mev3isj1" targetId="mev3isho"/>
                     </jumpTo>
                  </flow>
                  <link id="mev3ishp" targetId="mev3ishq" type="containerLink"/>
                  <link id="w123392a5-5b7d-464e-b4ae-d879fde5ae34"
                        targetId="a17MAawUYjIkOeVv7vGImAoE-me9omfcy"/>
                  <events>
                     <catch faultField="faultInfo" id="mev3ishn" interrupting="true">
                        <link id="mev3ishs" targetId="mev3isht" type="containerLink"/>
                     </catch>
                  </events>
               </eventContainer>
               <end id="a17MAawUYjIkOeVv7vGImAoE-md5qxiut">
