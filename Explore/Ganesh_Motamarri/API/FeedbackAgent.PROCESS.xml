            <flow id="b49691656-cf44-4fc0-85d5-bffb4743d277">
               <start id="v7ae34c02-cc86-4d54-9858-dd8d110ee0ee">
                  <link id="meu1putx" targetId="meu1putw"/>
               </start>
               <assignment id="meu1putw">
                  <title>Prepare Email Response Message</title>
                  <operation source="field" to="temp.Tmp_Zendesk_Ticket_Number">input.Planner[1]/Attributes[1]/ZendeskTicketNumber</operation>
                  <operation source="field" to="temp.Tmp_Zendesk_Ticket_Link">input.Planner[1]/Attributes[1]/ZendeskTicketLink</operation>
                  <operation source="field" to="temp.Tmp_Support_Company_Name">input.Planner[1]/Attributes[1]/SupportCompanyName</operation>
                  <operation source="field" to="temp.Tmp_Email_Address">input.Planner[1]/Attributes[1]/EmailAddress</operation>
                  <operation source="field" to="temp.Tmp_Email_Body">input.Planner[1]/Attributes[1]/EmailBody</operation>
                  <operation source="field" to="temp.Tmp_Email_Subject">input.Planner[1]/Attributes[1]/EmailSubject</operation>
                  <operation source="formula" to="temp.Tmp_Email_Message">
                     <expression language="XQuery">concat("Thank you for your feedback!", "&amp;#10;","&amp;#10;",
"This message is in response to your Zendesk ticket number ",$temp.Tmp_Zendesk_Ticket_Number   ,".","&amp;#10;","&amp;#10;","You can view the ticket here: ", $temp.Tmp_Zendesk_Ticket_Link   ,".","&amp;#10;","&amp;#10;"," We have received your suggestion and passed it along to our team.
Your input is incredibly valuable and helps us improve the tool to better meet your needs.", "&amp;#10;",
"If you have any more ideas or feedback, feel free to share them with us anytime! If you do not have any further questions, please mark the ticket as solved.", "&amp;#10;", "&amp;#10;",
"Your e-mail with feedback:", "&amp;#10;", "Subject: ",
$temp.Tmp_Email_Subject  , "&amp;#10;","&amp;#10;",
$temp.Tmp_Email_Body   , "&amp;#10;", "&amp;#10;",

"Kind Regards,", "&amp;#10;",
$temp.Tmp_Support_Company_Name  
)</expression>
                  </operation>
                  <link id="meu1puu6" targetId="mf4ifd17"/>
               </assignment>
               <assignment id="mf4ifd5g">
                  <title>Assignment to Tmp_Retry</title>
                  <operation source="constant" to="temp.Tmp_Retry">0</operation>
                  <link id="mf4ifd82" targetId="mf4ifd6f"/>
               </assignment>
               <assignment id="meu1puuj">
                  <title>Assign to PlannerOut</title>
                  <operation source="field" to="output.PlannerOut">input.Planner</operation>
                  <link id="meu1puuq" targetId="meu1puup"/>
               </assignment>
               <eventContainer id="mf4ifd17">
                  <service id="meu1puu5">
                     <title>Send Email To User</title>
                     <serviceName>EmailConnection-2:sendEmailService</serviceName>
                     <serviceGUID>1Kxuv8VY2UdkeJa32vKLo0</serviceGUID>
                     <serviceInput>
                        <parameter name="emailTaskInput" source="formula">
                           <expression language="XQuery">&lt;EmailTaskInput&gt;
   &lt;to&gt;{$temp.Tmp_Email_Address  }&lt;/to&gt;
   &lt;cc&gt;&lt;/cc&gt;
   &lt;bcc&gt;&lt;/bcc&gt;
   &lt;subject&gt;[FEEDBACK] has been submitted for Zendesk Ticket {$temp.Tmp_Zendesk_Ticket_Number  }&lt;/subject&gt;
   &lt;contentType&gt;&lt;/contentType&gt;
   &lt;body&gt;{$temp.Tmp_Email_Message  }&lt;/body&gt;
   &lt;attachments&gt;
      &lt;name&gt;&lt;/name&gt;
      &lt;content&gt;&lt;/content&gt;
      &lt;mimeType&gt;&lt;/mimeType&gt;
   &lt;/attachments&gt;
&lt;/EmailTaskInput&gt;
</expression>
                        </parameter>
                     </serviceInput>
                  </service>
                  <flow id="mf4ifd19">
                     <link id="mf4ifd1a" targetId="mf4ifd17" type="containerLink"/>
                  </flow>
                  <flow id="mf4ifd1c">
                     <subflow id="mf4ifd1i">
                        <title>GenericErrorHandlerEmail</title>
                        <subflowGUID>0n6qhvyIVgwlFmCA1wnzEx</subflowGUID>
                        <subflowPath>Generic_Error_Handler</subflowPath>
                        <runForEach>false</runForEach>
                        <input>
                           <parameter name="In_Code" source="field" updatable="true">output.faultInfo[1]/code</parameter>
                           <parameter name="In_Retry" source="field" updatable="true">temp.Tmp_Retry</parameter>
                           <parameter name="In_Service" source="constant" updatable="true">Email</parameter>
                        </input>
                        <outputDef>
                           <field name="Out_Retry" type="int">
                              <options>
                                 <option name="required">false</option>
                              </options>
                           </field>
                        </outputDef>
                        <link id="mf4ifd45" targetId="mf4ifd44"/>
                     </subflow>
                     <assignment id="mf4ifd44">
                        <title>Increment Retry Attempt</title>
                        <operation source="field" to="temp.Tmp_Retry">output.Out_Retry</operation>
                        <link id="mf4ifddk" targetId="mf4ifddi"/>
                     </assignment>
                     <jumpTo id="mf4ifddi">
                        <link id="mf4ifddj" targetId="mf4ifd17"/>
                     </jumpTo>
                  </flow>
                  <link id="mf4ifd18" targetId="mf4ifd19" type="containerLink"/>
                  <link id="mf4ifd5h" targetId="mf4ifd5g"/>
                  <events>
                     <catch faultField="faultInfo" id="mf4ifd16" interrupting="true">
                        <link id="mf4ifd1b" targetId="mf4ifd1c" type="containerLink"/>
                     </catch>
                  </events>
               </eventContainer>
               <eventContainer id="mf4ifd6f">
                  <service id="meu1puub">
                     <title>Update Zendesk Ticket With Comment</title>
                     <serviceName>ZendeskConnection:Update Object</serviceName>
                     <serviceGUID>7SV3vbmluGBiYrnCFJlWGB</serviceGUID>
                     <serviceInput>
                        <parameter name="entityType" source="constant">tickets</parameter>
                        <parameter name="entityId" source="field" updatable="true">temp.Tmp_Zendesk_Ticket_Number</parameter>
                        <parameter name="rawData" source="formula">
                           <expression language="XQuery">&lt;root xmlns:m="urn:informatica:ae:xquery:json2xml:meta-data"&gt;
&lt;ticket&gt;
&lt;status&gt;pending&lt;/status&gt;
&lt;subject&gt;[FEEDBACK] {$temp.Tmp_Email_Subject } &lt;/subject&gt;
&lt;comment&gt;
&lt;body&gt;{concat("Thank you for your feedback!", "&amp;#10;","&amp;#10;",
"We have received your suggestion and passed it along to our team.
Your input is incredibly valuable and helps us improve the tool to better meet your needs.", "&amp;#10;","&amp;#10;",
"If you have any more ideas or feedback, feel free to share them with us anytime! If you do not have any further questions, please mark the ticket as solved."
)  }&lt;/body&gt;
&lt;/comment&gt;
&lt;/ticket&gt;
&lt;/root&gt;</expression>
                        </parameter>
                     </serviceInput>
                  </service>
                  <flow id="mf4ifd6h">
                     <link id="mf4ifd6i" targetId="mf4ifd6f" type="containerLink"/>
                  </flow>
                  <flow id="mf4ifd6k">
                     <subflow id="mf4ifd8a">
                        <title>GenericErrorHandlerZendesk</title>
                        <subflowGUID>0n6qhvyIVgwlFmCA1wnzEx</subflowGUID>
                        <subflowPath>Generic_Error_Handler</subflowPath>
                        <runForEach>false</runForEach>
                        <input>
                           <parameter name="In_Code" source="field" updatable="true">output.faultInfo[1]/code</parameter>
                           <parameter name="In_Retry" source="field" updatable="true">temp.Tmp_Retry</parameter>
                           <parameter name="In_Service" source="constant" updatable="true">Zendesk</parameter>
                        </input>
                        <outputDef>
                           <field name="Out_Retry" type="int">
                              <options>
                                 <option name="required">false</option>
                              </options>
                           </field>
                        </outputDef>
                        <link id="mf4ifdb7" targetId="mf4ifdb6"/>
                     </subflow>
                     <assignment id="mf4ifdb6">
                        <title>Increment Retry Attempt</title>
                        <operation source="field" to="temp.Tmp_Retry">output.Out_Retry</operation>
                        <link id="mf4ifdeb" targetId="mf4ifde9"/>
                     </assignment>
                     <jumpTo id="mf4ifde9">
                        <link id="mf4ifdea" targetId="mf4ifd6f"/>
                     </jumpTo>
                  </flow>
                  <link id="mf4ifd6g" targetId="mf4ifd6h" type="containerLink"/>
                  <link id="meu1puuk" targetId="meu1puuj"/>
                  <events>
                     <catch faultField="faultInfo" id="mf4ifd6e" interrupting="true">
                        <link id="mf4ifd6j" targetId="mf4ifd6k" type="containerLink"/>
                     </catch>
                  </events>
               </eventContainer>
               <end id="meu1puup">
                  <title>End</title>
               </end>
            </flow>
         </process>
