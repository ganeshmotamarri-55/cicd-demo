               <assignment id="a194q0u3AFZene0LilFGrPwC-me9rz0ao">
                  <title>Prepare Jira Feature Request Ticket</title>
                  <operation source="formula" to="temp.Tmp_Jira_Ticket">
                     <expression language="XQuery">&lt;root&gt;
	&lt;fields&gt;
		&lt;summary&gt;{$input.In_Jira_Ticket_Summary   }&lt;/summary&gt;
		&lt;description&gt;{$input.In_Jira_Ticket_Description }&lt;/description&gt;
        &lt;project&gt;
			&lt;key&gt;{$input.In_Jira_Project_Key }&lt;/key&gt;
		&lt;/project&gt;
		&lt;issuetype&gt;
			&lt;name&gt;New Feature&lt;/name&gt;
		&lt;/issuetype&gt;
		&lt;priority&gt;
            &lt;name&gt;{$input.In_Jira_Ticket_Priority }&lt;/name&gt;
        &lt;/priority&gt;

        {if(fn:string-length($temp.Tmp_Assignee_Account_ID) != 0)
    then &lt;assignee&gt;
       &lt;accountId&gt;{$temp.Tmp_Assignee_Account_ID}&lt;/accountId&gt;
    &lt;/assignee&gt;
    else()
    }
    {if(fn:string-length($temp.Tmp_Reporter_Account_ID) != 0)
    then &lt;reporter&gt;
       &lt;accountId&gt;{$temp.Tmp_Reporter_Account_ID}&lt;/accountId&gt;
    &lt;/reporter&gt;
    else &lt;reporter&gt;
    &lt;/reporter&gt;
    }
	&lt;/fields&gt;
&lt;/root&gt;</expression>
                  </operation>
                  <link id="mf4j3xr6" targetId="mf4j3xm8"/>
               </assignment>
               <assignment id="a194q0u3AFZene0LilFGrPwC-me9rz0br">
                  <title>Set Jira Ticket Link and Number</title>
                  <operation source="formula" to="output.Out_Jira_Ticket_Link">
                     <expression language="XQuery">let $domain := substring-before($output.response/self/text(), "/rest")

let $issueKey := $output.response/key/text()
let $projectKey := $input.In_Jira_Project_Key 

let $url := concat(
  $domain,
  '/jira/servicedesk/projects/',
  $projectKey,
  '/issues/?jql=project=',
  $projectKey,
  '%20AND%20issueKey=',
  $issueKey
)

return $url
</expression>
                  </operation>
                  <operation source="formula" to="output.Out_Jira_Ticket_Number">
                     <expression language="XQuery">$output.response/key</expression>
                  </operation>
                  <link id="z5ff94d7e-aebe-487a-8c3f-9fe6c77a16b3"
