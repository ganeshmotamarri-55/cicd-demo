                              <operation source="formula" to="temp.Tmp_Prompt_Configuration">
                                 <expression language="XQuery">&lt;generationConfig&gt;
      &lt;stopSequences&gt;sadsadsad&lt;/stopSequences&gt;
      &lt;candidateCount&gt;1&lt;/candidateCount&gt;
      &lt;maxOutputTokens&gt;50000&lt;/maxOutputTokens&gt;
      &lt;temperature&gt;0.25&lt;/temperature&gt;
      &lt;topP&gt;0.5&lt;/topP&gt;
      &lt;topK&gt;2&lt;/topK&gt;
&lt;/generationConfig&gt;</expression>
                              </operation>
                              <operation source="formula" to="temp.Tmp_Request">
                                 <expression language="XQuery">let $articles-as-string :=
  string-join(
    for $c in $output.Out_Embeddings_Model_PO 
    let $score := $c/Score/string()
    let $text := $c/Text/string()
    return
      concat(
        "&lt;VectorMatchEntry-3&gt;&lt;Score&gt;", $score, "&lt;/Score&gt;&lt;Text&gt;",
        $text, "&lt;/Text&gt;&lt;/VectorMatchEntry-3&gt;"
      ),
    ''
  )
  


return &lt;Generate_Content_Request&gt;
   &lt;contents&gt;
      &lt;parts&gt;
         &lt;text&gt; {util:base64Encode(concat("You are an Informatica Support Query Agent specialized in answering user queries about Informatica products. Your task is to respond with information that can help solve the problems outlined in the user's input.  Prioritize the most applicable information that have the highest chance of helping user solve the user's problem. Avoid making up answers. 
Additionally, you receive a list of related articles extracted from Pinecone, each article provided in the following XML format:
&lt;VectorMatchEntry-3&gt;
&lt;Score&gt;...&lt;/Score&gt;
&lt;Text&gt;...&lt;/Text&gt;
&lt;/VectorMatchEntry-3&gt;
Please consider these articles as supplementary information to assist you in answering the query. Pay close attention to the &lt;Score&gt; tag in each article—the higher the score, the more relevant and important that article is. The articles are likely sorted from most to least important.
Do not rely solely on these articles; you should combine this information appropriately with your own knowledge base and understanding to generate the most accurate, helpful, and relevant answer.
The values based on which you should answer the question (E-Mail Subject, E-Mail Body and Articles) will be given below:
E-Mail Subject: ", $temp.Tmp_Email_Subject, "&amp;#10;",
"E-Mail Body: ", $temp.Tmp_Email_Body, "&amp;#10;",
"Articles: ", $articles-as-string, "&amp;#10;","&amp;#10;", "**Based on the above, generate a complete and helpful answer to the user's query. Do not describe your process. Just return the final answer.**"
))}&lt;/text&gt;
      &lt;/parts&gt;
      &lt;role&gt;user&lt;/role&gt;
   &lt;/contents&gt;
 &lt;generationConfig&gt;
      &lt;stopSequences&gt;{$temp.Tmp_Prompt_Configuration[1]/stopSequences}&lt;/stopSequences&gt;
      &lt;candidateCount&gt;{$temp.Tmp_Prompt_Configuration[1]/candidateCount }&lt;/candidateCount&gt;
      &lt;maxOutputTokens&gt;{$temp.Tmp_Prompt_Configuration[1]/maxOutputTokens }&lt;/maxOutputTokens&gt;
      &lt;temperature&gt;{$temp.Tmp_Prompt_Configuration[1]/temperature }&lt;/temperature&gt;
