pipeline {
    agent any

    stages {

        stage('Checkout DEV') {
            steps {
                deleteDir()

                git branch: 'dev',
                    credentialsId: 'github-creds',
                    url: 'https://github.com/ganeshmotamarri-55/cicd-demo.git'
            }
        }

        stage('Get Commit Message') {
            steps {
                script {
                    env.COMMIT_MSG = bat(
                        script: 'git log -1 --pretty=%%B',
                        returnStdout: true
                    ).trim()
                }
            }
        }

        stage('Send Approval Email') {
            steps {
                emailext(
                    to: 'ganeshmotamarri530@gmail.com',
                    subject: "Approval Required - DEV to QA Promotion",
                    body: """
Hello,

A new commit was pushed to DEV branch.

Latest Commit Message:
${env.COMMIT_MSG}

Please approve the deployment by opening Jenkins build URL below:

${env.BUILD_URL}input

After opening the link, click Proceed.

Regards,
Jenkins
"""
                )
            }
        }

        stage('Approval') {
            steps {
                input message: "Approve moving DEV changes to QA?\n\nLatest DEV Commit: ${env.COMMIT_MSG}",
                      ok: 'Approve'
            }
        }

        stage('Push to QA') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-creds',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {

                    bat '''
                    git config user.name "Jenkins"
                    git config user.email "jenkins@example.com"

                    git fetch origin
                    git checkout qa
                    git merge origin/dev --no-edit

                    git remote set-url origin https://%GIT_USER%:%GIT_TOKEN%@github.com/ganeshmotamarri-55/cicd-demo.git

                    git push origin qa
                    '''
                }
            }
        }

        stage('Success') {
            steps {
                echo 'DEV changes successfully moved to QA branch'
            }
        }
    }

    post {
        success {
            emailext(
                to: 'ganeshmotamarri530@gmail.com',
                subject: "Success - DEV moved to QA",
                body: "Deployment completed successfully.\n\nBuild URL: ${env.BUILD_URL}"
            )
        }

        failure {
            emailext(
                to: 'ganeshmotamarri530@gmail.com',
                subject: "Failed - DEV to QA Promotion",
                body: "Pipeline failed.\n\nBuild URL: ${env.BUILD_URL}"
            )
        }
    }
}
