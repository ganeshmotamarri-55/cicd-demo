pipeline {
    agent any

    stages {

        stage('Checkout DEV') {
            steps {
                deleteDir()

                git branch: 'dev',
                    credentialsId: 'github-creds',
                    url: 'https://github.com/ganeshmotamarri-55/cicd-demo.git'
            }
        }

        stage('Push to QA') {
            steps {
                bat '''
                git config user.name "Jenkins"
                git config user.email "jenkins@example.com"

                git fetch origin
                git checkout qa
                git merge origin/dev --no-edit
                git push origin qa
                '''
            }
        }

        stage('Success') {
            steps {
                echo 'DEV branch changes successfully pushed to QA branch'
            }
        }
    }

    post {
        failure {
            echo 'Pipeline failed. Check console output.'
        }
    }
}
