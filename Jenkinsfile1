pipeline {
    agent any

    stages {

        stage('Checkout DEV') {
            steps {
                git branch: 'dev',
                credentialsId: 'github-creds',
                url: 'https://github.com/ganeshmotamarri-55/cicd-demo.git'
            }
        }

        stage('Approval') {
            steps {
                input message: 'Approve push to QA branch?', ok: 'Approve'
            }
        }

        stage('Push to QA') {
            steps {
                bat '''
                git config user.name "Jenkins"
                git config user.email "jenkins@example.com"

                git fetch origin
                git checkout qa
                git merge origin/dev --no-edit
                git push origin qa
                '''
            }
        }
    }
}
