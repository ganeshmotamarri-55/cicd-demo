pipeline {
    agent any

    stages {

        stage('Checkout DEV') {
            steps {
                deleteDir()

                git branch: 'dev',
                    credentialsId: 'github-creds',
                    url: 'https://github.com/ganeshmotamarri-55/cicd-demo.git'
            }
        }

        stage('Approval') {
            steps {
                input message: 'Approve moving DEV changes to QA branch?', ok: 'Approve'
            }
        }

        stage('Push to QA') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-creds',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {

                    bat '''
                    git config user.name "Jenkins"
                    git config user.email "jenkins@example.com"

                    git fetch origin
                    git checkout qa
                    git merge origin/dev --no-edit

                    git remote set-url origin https://%GIT_USER%:%GIT_TOKEN%@github.com/ganeshmotamarri-55/cicd-demo.git

                    git push origin qa
                    '''
                }
            }
        }

        stage('Success') {
            steps {
                echo 'DEV branch changes successfully moved to QA branch'
            }
        }
    }

    post {
        failure {
            echo 'Pipeline failed. Check console logs.'
        }
    }
}
